# Runtime mode
NODE_ENV=production

# Render provides PORT automatically. Keep this for local testing.
PORT=3000

# CORS allowlist. Comma-separated origins.
# Example: ALLOWED_ORIGINS=https://your-app.onrender.com,https://www.yourdomain.com
ALLOWED_ORIGINS=

# Request/relay hardening
BODY_SIZE_LIMIT=1mb
REQUEST_TIMEOUT_MS=120000
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20
OLLAMA_TEST_TIMEOUT_MS=5000

# Security toggle for Ollama endpoint validation.
# false = block private/local network addresses to reduce SSRF risk.
# true  = allow private/local endpoints (for trusted/internal deployments only).
ALLOW_PRIVATE_OLLAMA_URLS=false
