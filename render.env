# Render environment variables template for TRAILS-Website
# Copy values into Render Dashboard -> Environment.

# Required
NODE_ENV=production
ALLOWED_ORIGINS=https://your-service-name.onrender.com

# Recommended security/defaults
ALLOW_PRIVATE_OLLAMA_URLS=false
REQUEST_TIMEOUT_MS=120000
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20
BODY_SIZE_LIMIT=1mb
OLLAMA_TEST_TIMEOUT_MS=5000

# Not required on Render (Render injects this automatically)
# PORT=10000
